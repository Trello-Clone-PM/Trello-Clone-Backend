    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.2",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=20"
  }
