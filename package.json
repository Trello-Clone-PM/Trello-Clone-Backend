{
  "name": "trello-clone-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted Trello clone backend (Express + Prisma, ESM JavaScript)",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "seed": "node src/db/seed.js",
